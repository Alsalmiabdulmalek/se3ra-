rules_version = '2';
// Se3ra sync rules: each signed-in user can read and write ONLY their own document
// at users/{their-uid}. No one can read or write anyone else's data, and unauthenticated
// requests are denied. Publish these in Firebase Console → Firestore → Rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
